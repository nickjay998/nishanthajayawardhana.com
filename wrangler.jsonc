{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nishanthajayawardhana-com",
  "compatibility_date": "2026-07-18",
  "assets": {
    "directory": "./public",
    "not_found_handling": "404-page"
  },
  "routes": [
    { "pattern": "nishanthajayawardhana.com", "custom_domain": true },
    { "pattern": "www.nishanthajayawardhana.com", "custom_domain": true }
  ],
  "observability": {
    "enabled": true
  }
}
